{
  "name": "@mohibzz/ferry",
  "version": "0.2.0",
  "description": "Generate a model-migration report so a team can safely switch LLM providers/models.",
  "type": "module",
  "bin": {
    "ferry": "dist/ferry.js"
  },
  "files": [
    "dist/",
    "ferry.config.json",
    "fixtures/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "esbuild src/ferry.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/ferry.js",
    "prepublishOnly": "npm run build",
    "ferry": "tsx src/ferry.ts",
    "test": "tsx src/lib.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@mohibzz/ferry": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
